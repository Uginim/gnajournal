---
const today = new Date();
---

<footer>
	<p>&copy; {today.getFullYear()} 그나저나 메모. All rights reserved.</p>
	<p class="powered-by">
		Powered by <a href="https://astro.build/" target="_blank" rel="noopener">Astro</a>
	</p>
</footer>

<style>
	footer {
		padding: 3em 1em;
		border-top: 1px solid var(--border);
		color: var(--text-muted);
		text-align: center;
		font-size: 0.85em;
		transition: all 0.3s ease;
	}
	footer p {
		margin: 0.3em 0;
	}
	.powered-by a {
		color: var(--text-muted);
		text-decoration: underline;
	}
	.powered-by a:hover {
		color: var(--accent);
	}
</style>
